# GROQ_API_KEY: Required for Groq Llama 3 API calls and Whisper.
# Users configure this via the Secrets panel in the AI Studio UI.
GROQ_API_KEY="your-groq-api-key"
GEMINI_API_KEY="your-gemini-api-key"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Google Calendar Service Account Credentials
GOOGLE_CALENDAR_ID="my_calendar_id@group.calendar.google.com"
GOOGLE_CLIENT_EMAIL="my-bot@my-project.iam.gserviceaccount.com"
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Supabase Realtime Database
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"

# Admin Telegram ID (for feedback notifications)
ADMIN_TELEGRAM_ID="your-admin-telegram-chat-id"

# Instagram Webhook Configuration
INSTAGRAM_VERIFY_TOKEN="your-random-verification-string-like-laser123"
INSTAGRAM_ACCESS_TOKEN="your-meta-graph-api-page-access-token"
INSTAGRAM_PAGE_ACCESS_TOKEN="your-meta-graph-api-page-access-token"

# Telegram Bot
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
TELEGRAM_TOKEN="your-telegram-bot-token"
